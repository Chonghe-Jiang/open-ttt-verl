# syntax=docker/dockerfile:1

ARG BASE_IMAGE=nvidia/cuda:13.0.2-devel-ubuntu24.04
FROM ${BASE_IMAGE}

ARG DEBIAN_FRONTEND=noninteractive
ARG PIP_NO_CACHE_DIR=1
ARG RUNTIME_LOCK=docker/b200_gptoss_env.lock.json
ARG INSTALL_LOCKED_RUNTIME=1
ARG PIP_EXTRA_INDEX_URL=https://download.pytorch.org/whl/cu130
ARG REBUILD_FLASH_ATTN=1
ARG FLASH_ATTN_VERSION=
ARG FLASH_ATTN_CUDA_ARCHS=90;100
ARG FLASH_ATTN_TORCH_CUDA_ARCH_LIST=9.0;10.0
ARG FLASH_ATTN_MAX_JOBS=8
ARG FLASH_ATTN_NVCC_THREADS=4
ARG FLASH_ATTN_CUDA_HOME=

ENV PIP_NO_CACHE_DIR=${PIP_NO_CACHE_DIR} \
    PIP_EXTRA_INDEX_URL=${PIP_EXTRA_INDEX_URL} \
    VIRTUAL_ENV=/opt/ttt_venv \
    PATH=/opt/ttt_venv/bin:${PATH} \
    PYTHONUNBUFFERED=1 \
    HF_HOME=/hf_cache \
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    HYDRA_FULL_ERROR=1 \
    RAY_DEDUP_LOGS=0 \
    USE_HUB_KERNELS=0 \
    NCCL_P2P_DISABLE=0 \
    NCCL_SHM_DISABLE=0 \
    NCCL_IB_DISABLE=1

SHELL ["/bin/bash", "-o", "pipefail", "-c"]

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      build-essential \
      ca-certificates \
      curl \
      git \
      python-is-python3 \
      python3 \
      python3-dev \
      python3-pip \
      python3-venv && \
    python3 -m venv "${VIRTUAL_ENV}" && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /workspace/open-ttt-verl

COPY . .

# The base image supplies OS/CUDA tooling. The Python GPU stack is installed
# from the lock file and verified before the image is considered usable.
RUN python -m pip install --upgrade pip setuptools wheel packaging ninja && \
    if [[ "${INSTALL_LOCKED_RUNTIME}" == "1" ]]; then \
      python scripts/ttt_discover/env_fingerprint.py \
        --lock "${RUNTIME_LOCK}" \
        --emit-pip-requirements \
        --exclude flash-attn > /tmp/ttt_runtime_requirements.txt && \
      cat /tmp/ttt_runtime_requirements.txt && \
      python -m pip install --no-cache-dir --force-reinstall -r /tmp/ttt_runtime_requirements.txt; \
    else \
      echo "Skipping locked runtime install because INSTALL_LOCKED_RUNTIME=${INSTALL_LOCKED_RUNTIME}"; \
    fi && \
    if [[ "${REBUILD_FLASH_ATTN}" == "1" ]]; then \
      LOCKED_FLASH_ATTN_VERSION="$(python scripts/ttt_discover/env_fingerprint.py --lock "${RUNTIME_LOCK}" --package-version flash-attn)" && \
      FLASH_ATTN_BUILD_VERSION="${FLASH_ATTN_VERSION:-${LOCKED_FLASH_ATTN_VERSION}}" && \
      TORCH_CUDA="$(python -c 'import torch; print(torch.version.cuda or "")')" && \
      if [[ -z "${TORCH_CUDA}" ]]; then \
        echo "PyTorch reports no CUDA runtime; cannot build flash-attn" >&2; \
        exit 1; \
      fi && \
      CUDA_DIR="${FLASH_ATTN_CUDA_HOME}" && \
      if [[ -z "${CUDA_DIR}" ]]; then \
        CUDA_DIR="/usr/local/cuda-${TORCH_CUDA}"; \
      fi && \
      if [[ ! -x "${CUDA_DIR}/bin/nvcc" ]]; then \
        CUDA_DIR="/usr/local/cuda"; \
      fi && \
      if [[ ! -x "${CUDA_DIR}/bin/nvcc" ]]; then \
        echo "No nvcc found. Set FLASH_ATTN_CUDA_HOME to a CUDA toolkit matching torch.version.cuda=${TORCH_CUDA}." >&2; \
        exit 1; \
      fi && \
      echo "Building flash-attn ${FLASH_ATTN_BUILD_VERSION} with torch CUDA ${TORCH_CUDA}, CUDA_HOME=${CUDA_DIR}, FLASH_ATTN_CUDA_ARCHS=${FLASH_ATTN_CUDA_ARCHS}" && \
      "${CUDA_DIR}/bin/nvcc" --version && \
      CUDA_HOME="${CUDA_DIR}" \
      CUDACXX="${CUDA_DIR}/bin/nvcc" \
      PATH="${CUDA_DIR}/bin:${PATH}" \
      FLASH_ATTN_CUDA_ARCHS="${FLASH_ATTN_CUDA_ARCHS}" \
      TORCH_CUDA_ARCH_LIST="${FLASH_ATTN_TORCH_CUDA_ARCH_LIST}" \
      MAX_JOBS="${FLASH_ATTN_MAX_JOBS}" \
      NVCC_THREADS="${FLASH_ATTN_NVCC_THREADS}" \
      FLASH_ATTENTION_FORCE_BUILD=TRUE \
        python -m pip install --no-build-isolation --force-reinstall --no-deps \
          --no-binary=flash-attn --no-cache-dir "flash-attn==${FLASH_ATTN_BUILD_VERSION}"; \
    else \
      echo "Skipping flash-attn rebuild because REBUILD_FLASH_ATTN=${REBUILD_FLASH_ATTN}"; \
    fi && \
    python -m pip install --no-deps -e . && \
    python -m pip install \
      "huggingface_hub[cli]" \
      hf_transfer \
      protobuf \
      sentencepiece \
      tiktoken \
      math-verify && \
    python -m compileall -q verl_ttt_discover scripts/ttt_discover && \
    python scripts/ttt_discover/env_fingerprint.py \
      --compare-lock "${RUNTIME_LOCK}" \
      --forbid-vllm-flash-attn3 && \
    mkdir -p /hf_cache outputs

ENTRYPOINT ["/bin/bash"]
