{
  "schema_version": 1,
  "description": "Runtime package lock for the validated non-Docker Blackwell GPT-OSS TTT environment. Regenerate with scripts/ttt_discover/env_fingerprint.py on the source B200 environment if that environment changes.",
  "env": {
    "USE_HUB_KERNELS": "0"
  },
  "install": {
    "pip_extra_index_url": "https://download.pytorch.org/whl/cu130"
  },
  "python": {
    "version": "3.13.12"
  },
  "gpu": {
    "devices": [
      {
        "name": "NVIDIA RTX PRO 6000 Blackwell Max-Q Workstation Edition",
        "capability": [
          12,
          0
        ]
      }
    ]
  },
  "packages": {
    "torch": {
      "dist_version": "2.11.0",
      "import_version": "2.11.0+cu130",
      "importable": true,
      "torch_cuda": "13.0"
    },
    "vllm": {
      "dist_version": "0.21.0",
      "import_version": "0.21.0",
      "importable": true
    },
    "transformers": {
      "dist_version": "5.9.0",
      "import_version": "5.9.0",
      "importable": true
    },
    "flash-attn": {
      "dist_version": "2.8.3",
      "import_version": "2.8.3",
      "importable": true
    },
    "triton": {
      "dist_version": "3.6.0",
      "import_version": "3.6.0",
      "importable": true
    },
    "flashinfer-python": {
      "dist_version": "0.6.8.post1"
    },
    "ray": {
      "dist_version": "2.55.1",
      "import_version": "2.55.1",
      "importable": true
    },
    "peft": {
      "dist_version": "0.19.1",
      "import_version": "0.19.1",
      "importable": true
    },
    "accelerate": {
      "dist_version": "1.13.0",
      "import_version": "1.13.0",
      "importable": true
    },
    "tensordict": {
      "dist_version": "0.10.0",
      "import_version": "0.10.0",
      "importable": true
    },
    "torchdata": {
      "dist_version": "0.11.0",
      "import_version": "0.11.0+cpu",
      "importable": true
    },
    "datasets": {
      "dist_version": "4.8.5",
      "import_version": "4.8.5",
      "importable": true
    },
    "hydra-core": {
      "dist_version": "1.3.2",
      "import_version": "1.3.2",
      "importable": true
    },
    "sentencepiece": {
      "dist_version": "0.2.1",
      "import_version": "0.2.1",
      "importable": true
    },
    "tiktoken": {
      "dist_version": "0.12.0",
      "import_version": "0.12.0",
      "importable": true
    },
    "protobuf": {
      "dist_version": "6.33.6",
      "import_version": "6.33.6",
      "importable": true
    }
  }
}
